generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CLUB_ADMIN
  MANAGER
  RECEPTION
  INSTRUCTOR
  PLAYER
  PARENT
  CASUAL_USER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
  PENDING_VERIFICATION
}

enum ClubStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  TRIAL
  LOCKED
}

enum SurfaceType {
  CLAY
  HARD
  GRASS
  SYNTHETIC
  CARPET
  INDOOR_HARD
}

enum ReservationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentMethod {
  MANUAL_CASH
  MANUAL_CARD
  MANUAL_TRANSFER
  ONLINE_CARD
  CLUB_CREDIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
  LIFETIME
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
  DOUBLES
  MIXED
  LEAGUE
}

/// Sub-bracket within a tournament. Promotional / playoff style brackets have
/// separate winners and losers sub-brackets once a player loses in the main
/// bracket. Bracket metadata is intentionally separate from `round` so a
/// stage promotion-playoff can carry BOTH (round="SF" + stage="LOSERS") etc.
enum BracketStage {
  MAIN
  WINNERS
  LOSERS
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  WALKOVER
}

enum NotificationType {
  RESERVATION_CONFIRMED
  RESERVATION_CANCELLED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  TOURNAMENT_REGISTRATION
  MATCH_SCHEDULED
  RESULT_ENTERED
  MEMBERSHIP_EXPIRING
  MATCH_INVITATION_RECEIVED
  MATCH_INVITATION_ACCEPTED
  MATCH_INVITATION_DECLINED
  GENERAL
}

enum CourtBlockType {
  MAINTENANCE
  PRIVATE_EVENT
  STAFF
  OTHER
}

enum PlayerLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPETITIVE
  PROFESSIONAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum MatchLogType {
  MATCH
  TRAINING
  COACHING
  FITNESS
}

enum ClubMatchResultSource {
  UPLOAD
  MANUAL
}

enum RankingSeasonStatus {
  ACTIVE
  CLOSED
}

enum ParentChildLinkStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipRequestStatus {
  PENDING
  APPROVED
  DENIED
}

/// Platform-defined announcement categories. A player can mute each one
/// independently via PlayerNotificationPreference. Direct transactional
/// notifications (booking confirmations, 2FA codes, payment confirmations,
/// direct match invitations, parent/child approvals, role changes) do NOT
/// flow through this enum — they always go through the unconditional
/// `Notification` create path.
enum NotificationCategory {
  EVENTS
  OFFERS
  MEMBERSHIP_OFFERS
  MATCH_FINDING
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  phone        String?
  role         Role       @default(PLAYER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  emailVerifiedAt         DateTime? @map("email_verified_at")
  emailVerificationToken  String?   @unique @map("email_verification_token")
  emailVerificationExpiry DateTime? @map("email_verification_expiry")
  passwordResetToken      String?   @unique @map("password_reset_token")
  passwordResetExpiry     DateTime? @map("password_reset_expiry")
  expoPushToken           String?   @map("expo_push_token")
  staffClubId             String?   @map("staff_club_id")

  // 2FA (Stage 2b)
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorCode       String?   @map("two_factor_code")
  twoFactorExpiry     DateTime? @map("two_factor_expiry")
  twoFactorLoginToken String?   @unique @map("two_factor_login_token")

  playerProfile             PlayerProfile?
  reservations              Reservation[]                 @relation("UserReservations")
  createdReservations       Reservation[]                 @relation("CreatedReservations")
  payments                  Payment[]                     @relation("UserPayments")
  confirmedPayments         Payment[]                     @relation("ConfirmedPayments")
  notifications             Notification[]
  instructorProfiles        Instructor[]
  ownedClubs                Club[]
  auditLogs                 AuditLog[]                    @relation("ActorLogs")
  refreshTokens             RefreshToken[]
  rankings                  Ranking[]
  enteredClubMatchResults   ClubMatchResult[]
  sentClubAnnouncements     ClubAnnouncement[]            @relation("ClubAnnouncementSender")
  givenBonusAwards          ClubBonusPointAward[]
  parentLinks               ParentChildLink[]             @relation("ParentLinks")
  childLinks                ParentChildLink[]             @relation("ChildLinks")
  approvedLinks             ParentChildLink[]             @relation("ApprovedLinks")
  actedPayments             Payment[]                     @relation("ActedPayments")
  actedRegistrations        TournamentRegistration[]      @relation("ActedRegistrations")
  registeredRegistrations   TournamentRegistration[]      @relation("RegisteredRegistrations")
  actedInvitations          MatchInvitation[]             @relation("ActedInvitations")
  membershipRequests        MembershipRequest[]           @relation("MembershipRequestRequester")
  decidedMembershipRequests MembershipRequest[]           @relation("MembershipRequestDecider")
  clubFavorites             ClubFavorite[]
  notificationPreferences   PlayerNotificationPreference?

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── PLAYER PROFILE ──────────────────────────────────────────────────────────

model PlayerProfile {
  id               String      @id @default(uuid())
  userId           String      @unique @map("user_id")
  displayName      String      @map("display_name")
  // Stage 15 — split identity fields used for roster matching.
  // Per the privacy model these are SHARED with clubs on which the player
  // has any affiliation (linked roster, membership, or home club selection);
  // RUT is **not** used for matching and stays private to the user.
  firstName        String?     @map("first_name")
  lastName         String?     @map("last_name")
  profilePhotoUrl  String?     @map("profile_photo_url")
  bio              String?
  dateOfBirth      DateTime?   @map("date_of_birth")
  gender           Gender?
  dominantHand     String?     @map("dominant_hand")
  playingStyle     String?     @map("playing_style")
  level            PlayerLevel @default(BEGINNER)
  category         String?
  homeClubId       String?     @map("home_club_id")
  publicVisibility Boolean     @default(true) @map("public_visibility")

  // Stage 3 — player discovery
  comuna                String?   @map("comuna")
  availableForMatch     Boolean   @default(false) @map("available_for_match")
  availableWeekdays     Boolean   @default(false) @map("available_weekdays")
  availableWeekends     Boolean   @default(false) @map("available_weekends")
  showPhotoInSearch     Boolean   @default(true) @map("show_photo_in_search")
  shareStatsWithClub    Boolean   @default(true) @map("share_stats_with_club")
  shareStatsWithPlayers Boolean   @default(false) @map("share_stats_with_players")
  lastKnownLatitude     Float?    @map("last_known_latitude")
  lastKnownLongitude    Float?    @map("last_known_longitude")
  locationUpdatedAt     DateTime? @map("location_updated_at")
  runPlayerId           String?   @map("run_player_id")
  runRankCached         Int?      @map("run_rank_cached")
  runPointsCached       Int?      @map("run_points_cached")
  runAtpPointsCached    Int?      @map("run_atp_points_cached")
  runLastSyncedAt       DateTime? @map("run_last_synced_at")

  // Stage 6 — RUT for roster linking
  rut String? @unique

  // Stage 10 — parent/child accounts
  canTransact    Boolean @default(true) @map("can_transact")
  isMinorAccount Boolean @default(false) @map("is_minor_account")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeClub Club?        @relation(fields: [homeClubId], references: [id])
  stats    PlayerStats?

  sentInvitations     MatchInvitation[]  @relation("SentInvitations")
  receivedInvitations MatchInvitation[]  @relation("ReceivedInvitations")
  ownedMatchLogs      MatchLogEntry[]    @relation("OwnedMatchLogs")
  opponentMatchLogs   MatchLogEntry[]    @relation("OpponentMatchLogs")
  rosterLinks         ClubPlayerRoster[] @relation("RosterLink")

  @@map("player_profiles")
}

model PlayerStats {
  id                String @id @default(uuid())
  playerId          String @unique @map("player_id")
  matchesPlayed     Int    @default(0) @map("matches_played")
  wins              Int    @default(0)
  losses            Int    @default(0)
  tournamentsPlayed Int    @default(0) @map("tournaments_played")
  titles            Int    @default(0)
  rankingPoints     Int    @default(0) @map("ranking_points")
  currentRank       Int?   @map("current_rank")
  winRate           Float  @default(0) @map("win_rate")

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_stats")
}

// ─── CLUBS ───────────────────────────────────────────────────────────────────

model Club {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  status      ClubStatus @default(ACTIVE)
  ownerUserId String     @map("owner_user_id")
  trialEndsAt DateTime?  @map("trial_ends_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner              User                  @relation(fields: [ownerUserId], references: [id])
  profile            ClubProfile?
  photos             ClubPhoto[]
  openingHours       ClubOpeningHour[]
  specialHours       ClubSpecialHour[]
  courts             Court[]
  instructors        Instructor[]
  memberships        Membership[]
  membershipPlans    MembershipPlan[]
  reservations       Reservation[]
  payments           Payment[]
  tournaments        Tournament[]
  rankings           Ranking[]
  playerProfiles     PlayerProfile[]
  clubRankingRules   ClubRankingRule[]
  clubRankingEntries ClubRankingEntry[]
  clubMatchResults   ClubMatchResult[]
  announcements      ClubAnnouncement[]
  rosterEntries      ClubPlayerRoster[]
  rankingSeasons     RankingSeason[]
  divisionConfigs    ClubDivisionConfig[]
  bonusPointTypes    ClubBonusPointType[]
  bonusPointAwards   ClubBonusPointAward[]
  parentChildLinks   ParentChildLink[]
  membershipRequests MembershipRequest[]
  favoritedBy        ClubFavorite[]

  @@map("clubs")
}

model ClubProfile {
  id                         String   @id @default(uuid())
  clubId                     String   @unique @map("club_id")
  logoUrl                    String?  @map("logo_url")
  bannerUrl                  String?  @map("banner_url")
  description                String?
  address                    String?
  city                       String?
  region                     String?
  country                    String   @default("Chile")
  latitude                   Float?
  longitude                  Float?
  phone                      String?
  whatsapp                   String?
  email                      String?
  instagram                  String?
  website                    String?
  rules                      String?
  cancellationPolicy         String?  @map("cancellation_policy")
  accentColor                String?  @map("accent_color")
  defaultPaymentInstructions String?  @map("default_payment_instructions")
  paymentMethods             String[] @map("payment_methods")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_profiles")
}

model ClubPhoto {
  id           String  @id @default(uuid())
  clubId       String  @map("club_id")
  photoUrl     String  @map("photo_url")
  caption      String?
  displayOrder Int     @default(0) @map("display_order")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_photos")
}

model ClubOpeningHour {
  id        String  @id @default(uuid())
  clubId    String  @map("club_id")
  dayOfWeek Int     @map("day_of_week")
  openTime  String  @map("open_time")
  closeTime String  @map("close_time")
  isClosed  Boolean @default(false) @map("is_closed")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, dayOfWeek])
  @@map("club_opening_hours")
}

model ClubSpecialHour {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  date      DateTime
  openTime  String?  @map("open_time")
  closeTime String?  @map("close_time")
  isClosed  Boolean  @default(false) @map("is_closed")
  reason    String?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_special_hours")
}

// ─── COURTS ──────────────────────────────────────────────────────────────────

model Court {
  id          String      @id @default(uuid())
  clubId      String      @map("club_id")
  name        String
  description String?
  surfaceType SurfaceType @map("surface_type")
  indoor      Boolean     @default(false)
  lighting    Boolean     @default(false)
  active      Boolean     @default(true)
  photoUrl    String?     @map("photo_url")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  club         Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  pricing      CourtPricing[]
  blocks       CourtBlock[]
  reservations Reservation[]
  matches      Match[]

  @@map("courts")
}

model CourtPricing {
  id           String @id @default(uuid())
  courtId      String @map("court_id")
  userType     String @map("user_type")
  price        Float
  currency     String @default("CLP")
  peakPrice    Float? @map("peak_price")
  offPeakPrice Float? @map("off_peak_price")

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([courtId, userType])
  @@map("court_pricing")
}

model CourtBlock {
  id        String         @id @default(uuid())
  courtId   String         @map("court_id")
  startTime DateTime       @map("start_time")
  endTime   DateTime       @map("end_time")
  reason    String?
  blockType CourtBlockType @default(MAINTENANCE) @map("block_type")
  createdBy String         @map("created_by")
  createdAt DateTime       @default(now()) @map("created_at")

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_blocks")
}

// ─── INSTRUCTORS ─────────────────────────────────────────────────────────────

model Instructor {
  id              String   @id @default(uuid())
  clubId          String   @map("club_id")
  userId          String?  @map("user_id")
  name            String
  photoUrl        String?  @map("photo_url")
  bio             String?
  experienceYears Int      @default(0) @map("experience_years")
  specialties     String[]
  certifications  String[]
  hourlyRate      Float?   @map("hourly_rate")
  active          Boolean  @default(true)

  club         Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user         User?                    @relation(fields: [userId], references: [id], map: "instructor_user_fk")
  availability InstructorAvailability[]

  @@map("instructors")
}

model InstructorAvailability {
  id           String @id @default(uuid())
  instructorId String @map("instructor_id")
  dayOfWeek    Int    @map("day_of_week")
  startTime    String @map("start_time")
  endTime      String @map("end_time")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("instructor_availability")
}

// ─── MEMBERSHIPS ─────────────────────────────────────────────────────────────

model MembershipPlan {
  id                  String        @id @default(uuid())
  clubId              String        @map("club_id")
  name                String
  description         String?
  price               Float
  billingPeriod       BillingPeriod @map("billing_period")
  benefits            String[]
  active              Boolean       @default(true)
  paymentInstructions String?       @map("payment_instructions")

  club               Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  membershipRequests MembershipRequest[]

  @@map("membership_plans")
}

model Membership {
  id          String           @id @default(uuid())
  rosterId    String           @map("roster_id")
  clubId      String           @map("club_id")
  planId      String           @map("plan_id")
  status      MembershipStatus @default(ACTIVE)
  startDate   DateTime         @map("start_date")
  endDate     DateTime?        @map("end_date")
  renewalType String?          @map("renewal_type")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  roster   ClubPlayerRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  club     Club             @relation(fields: [clubId], references: [id])
  plan     MembershipPlan   @relation(fields: [planId], references: [id])
  payments Payment[]

  @@map("memberships")
}

model MembershipRequest {
  id                String                  @id @default(uuid())
  clubId            String                  @map("club_id")
  planId            String                  @map("plan_id")
  requestedByUserId String                  @map("requested_by_user_id")
  status            MembershipRequestStatus @default(PENDING)
  requestedAt       DateTime                @default(now()) @map("requested_at")
  decidedAt         DateTime?               @map("decided_at")
  decidedByUserId   String?                 @map("decided_by_user_id")
  denialReason      String?                 @map("denial_reason")

  club            Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  plan            MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  requestedByUser User           @relation("MembershipRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  decidedByUser   User?          @relation("MembershipRequestDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([clubId, status])
  @@index([requestedByUserId, status])
  @@map("membership_requests")
}

// ─── RESERVATIONS ────────────────────────────────────────────────────────────

model Reservation {
  id            String            @id @default(uuid())
  clubId        String            @map("club_id")
  courtId       String            @map("court_id")
  userId        String            @map("user_id")
  startTime     DateTime          @map("start_time")
  endTime       DateTime          @map("end_time")
  status        ReservationStatus @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus     @default(PENDING) @map("payment_status")
  price         Float
  currency      String            @default("CLP")
  createdBy     String            @map("created_by")
  notes         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  club          Club      @relation(fields: [clubId], references: [id])
  court         Court     @relation(fields: [courtId], references: [id])
  user          User      @relation("UserReservations", fields: [userId], references: [id])
  createdByUser User      @relation("CreatedReservations", fields: [createdBy], references: [id])
  payments      Payment[]

  @@map("reservations")
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────

model Payment {
  id                       String        @id @default(uuid())
  clubId                   String        @map("club_id")
  userId                   String        @map("user_id")
  reservationId            String?       @map("reservation_id")
  tournamentRegistrationId String?       @map("tournament_registration_id")
  membershipId             String?       @map("membership_id")
  amount                   Float
  currency                 String        @default("CLP")
  method                   PaymentMethod @default(MANUAL_CASH)
  status                   PaymentStatus @default(PENDING)
  paidAt                   DateTime?     @map("paid_at")
  confirmedBy              String?       @map("confirmed_by")
  actedByUserId            String?       @map("acted_by_user_id")
  notes                    String?
  reference                String?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  club                   Club                    @relation(fields: [clubId], references: [id])
  user                   User                    @relation("UserPayments", fields: [userId], references: [id])
  reservation            Reservation?            @relation(fields: [reservationId], references: [id])
  membership             Membership?             @relation(fields: [membershipId], references: [id])
  confirmedByUser        User?                   @relation("ConfirmedPayments", fields: [confirmedBy], references: [id])
  actedByUser            User?                   @relation("ActedPayments", fields: [actedByUserId], references: [id])
  tournamentRegistration TournamentRegistration? @relation(fields: [tournamentRegistrationId], references: [id])

  @@map("payments")
}

// ─── TOURNAMENTS ─────────────────────────────────────────────────────────────

model Tournament {
  id                    String           @id @default(uuid())
  clubId                String           @map("club_id")
  name                  String
  description           String?
  startDate             DateTime         @map("start_date")
  endDate               DateTime         @map("end_date")
  registrationOpenDate  DateTime?        @map("registration_open_date")
  registrationCloseDate DateTime?        @map("registration_close_date")
  status                TournamentStatus @default(DRAFT)
  format                TournamentFormat @default(SINGLE_ELIMINATION)
  price                 Float            @default(0)
  maxPlayers            Int?             @map("max_players")
  createdBy             String           @map("created_by")
  /// Interclub label — plain text opponent club name, no cross-tenant linkage.
  /// Full cross-club interclub is intentionally deferred to post-launch.
  opponentClubName      String?          @map("opponent_club_name")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  club          Club                     @relation(fields: [clubId], references: [id])
  categories    TournamentCategory[]
  registrations TournamentRegistration[]
  matches       Match[]
  teams         TournamentTeam[]

  @@map("tournaments")
}

model TournamentCategory {
  id           String  @id @default(uuid())
  tournamentId String  @map("tournament_id")
  name         String
  levelMin     String? @map("level_min")
  levelMax     String? @map("level_max")
  gender       String?
  ageGroup     String? @map("age_group")
  maxPlayers   Int?    @map("max_players")

  tournament    Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registrations TournamentRegistration[]
  matches       Match[]
  teams         TournamentTeam[]

  @@map("tournament_categories")
}

/// A doubles partnership in a DOUBLES-format tournament. Both players are real
/// roster entries — having an app account is optional. For SINGLES/ROUND_ROBIN
/// tournaments, registrations reference a roster entry directly (TournamentRegistration.rosterId)
/// and this model is unused.
model TournamentTeam {
  id              String   @id @default(uuid())
  tournamentId    String   @map("tournament_id")
  categoryId      String   @map("category_id")
  player1RosterId String   @map("player1_roster_id")
  player2RosterId String   @map("player2_roster_id")
  group           String?
  label           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tournament      Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category        TournamentCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  player1Roster   ClubPlayerRoster         @relation("TeamPlayer1", fields: [player1RosterId], references: [id])
  player2Roster   ClubPlayerRoster         @relation("TeamPlayer2", fields: [player2RosterId], references: [id])
  registrations   TournamentRegistration[]
  matchesAsOne    Match[]                  @relation("MatchTeamOne")
  matchesAsTwo    Match[]                  @relation("MatchTeamTwo")
  matchesAsWinner Match[]                  @relation("MatchTeamWinner")

  @@unique([tournamentId, categoryId, player1RosterId, player2RosterId])
  @@index([tournamentId, categoryId])
  @@map("tournament_teams")
}

/// Registration for a tournament. Always points to a roster entry; the optional
/// `registeredByUserId` records the staff/member who submitted the registration
/// (null when there is no app account behind this registration at all).
/// For DOUBLES-format tournaments the registration is keyed off `teamId` instead
/// of `rosterId`, and `rosterId` is null — exactly one of rosterId/teamId is set.
model TournamentRegistration {
  id                 String        @id @default(uuid())
  tournamentId       String        @map("tournament_id")
  categoryId         String        @map("category_id")
  rosterId           String?       @map("roster_id")
  teamId             String?       @map("team_id")
  actedByUserId      String?       @map("acted_by_user_id")
  registeredByUserId String?       @map("registered_by_user_id")
  status             String        @default("PENDING")
  paymentStatus      PaymentStatus @default(PENDING) @map("payment_status")
  seedNumber         Int?          @map("seed_number")
  registeredAt       DateTime      @default(now()) @map("registered_at")

  tournament       Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category         TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  roster           ClubPlayerRoster?  @relation("RosterRegistrations", fields: [rosterId], references: [id], onDelete: Cascade)
  team             TournamentTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  actedByUser      User?              @relation("ActedRegistrations", fields: [actedByUserId], references: [id])
  registeredByUser User?              @relation("RegisteredRegistrations", fields: [registeredByUserId], references: [id])
  payments         Payment[]

  @@index([tournamentId, categoryId, rosterId])
  @@index([tournamentId, categoryId, teamId])
  @@index([rosterId])
  @@map("tournament_registrations")
}

// ─── MATCHES ─────────────────────────────────────────────────────────────────

model Match {
  id                String       @id @default(uuid())
  tournamentId      String?      @map("tournament_id")
  categoryId        String?      @map("category_id")
  round             String?
  /// Sub-bracket within a tournament. MAIN for the primary bracket,
  /// WINNERS for the bracket feeding the final of a winners' tournament
  /// stage, LOSERS for the consolation/loss bracket of a promotional
  /// playoff structure. Independent of `round` (round="SF" + stage="LOSERS"
  /// is a valid state for promotion playoffs).
  bracketStage      BracketStage @default(MAIN) @map("bracket_stage")
  // Singles-style refs — either roster OR team refs must be set; both optional.
  playerOneRosterId String?      @map("player_one_roster_id")
  playerTwoRosterId String?      @map("player_two_roster_id")
  winnerRosterId    String?      @map("winner_roster_id")
  // Doubles-style refs.
  teamOneId         String?      @map("team_one_id")
  teamTwoId         String?      @map("team_two_id")
  teamWinnerId      String?      @map("team_winner_id")
  playerOneScore    String?      @map("player_one_score")
  playerTwoScore    String?      @map("player_two_score")
  setScores         Json?        @map("set_scores")
  scheduledTime     DateTime?    @map("scheduled_time")
  courtId           String?      @map("court_id")
  status            MatchStatus  @default(SCHEDULED)
  notes             String?
  /// Interclub label — plain text opponent club name (overrides tournament-level
  /// for the rare case of mixed-roster ties). No cross-tenant linkage.
  opponentClubName  String?      @map("opponent_club_name")
  recordedAt        DateTime?    @map("recorded_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  tournament      Tournament?         @relation(fields: [tournamentId], references: [id])
  category        TournamentCategory? @relation(fields: [categoryId], references: [id])
  playerOneRoster ClubPlayerRoster?   @relation("MatchPlayerOne", fields: [playerOneRosterId], references: [id], onDelete: SetNull)
  playerTwoRoster ClubPlayerRoster?   @relation("MatchPlayerTwo", fields: [playerTwoRosterId], references: [id], onDelete: SetNull)
  winnerRoster    ClubPlayerRoster?   @relation("MatchWinner", fields: [winnerRosterId], references: [id], onDelete: SetNull)
  teamOne         TournamentTeam?     @relation("MatchTeamOne", fields: [teamOneId], references: [id], onDelete: SetNull)
  teamTwo         TournamentTeam?     @relation("MatchTeamTwo", fields: [teamTwoId], references: [id], onDelete: SetNull)
  teamWinner      TournamentTeam?     @relation("MatchTeamWinner", fields: [teamWinnerId], references: [id], onDelete: SetNull)
  court           Court?              @relation(fields: [courtId], references: [id])

  @@index([tournamentId, bracketStage, round])
  @@index([playerOneRosterId])
  @@index([playerTwoRosterId])
  @@index([teamOneId])
  @@index([teamTwoId])
  @@map("matches")
}

// ─── RANKINGS ────────────────────────────────────────────────────────────────

model Ranking {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  playerId  String   @map("player_id")
  category  String
  points    Int      @default(0)
  rank      Int?
  season    String
  updatedAt DateTime @updatedAt @map("updated_at")

  club   Club @relation(fields: [clubId], references: [id])
  player User @relation(fields: [playerId], references: [id])

  @@unique([clubId, playerId, category, season])
  @@map("rankings")
}

// ─── CLUB RANKING SYSTEM (Stage 5 → Stage 6) ─────────────────────────────────

model ClubRankingRule {
  id           String   @id @default(uuid())
  clubId       String   @map("club_id")
  categoryKey  String   @map("category_key")
  label        String
  winnerPoints Int      @map("winner_points")
  loserPoints  Int      @map("loser_points")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, categoryKey])
  @@map("club_ranking_rules")
}

// Stage 6 — durable per-club member record; canonical identity for all ranking operations
model ClubPlayerRoster {
  id                    String    @id @default(uuid())
  clubId                String    @map("club_id")
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  dateOfBirth           DateTime? @map("date_of_birth")
  rut                   String?
  phone                 String?
  address               String?
  suburb                String?
  postcode              String?
  city                  String?
  division              String?
  linkedPlayerProfileId String?   @map("linked_player_profile_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  club                    Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  linkedPlayerProfile     PlayerProfile?           @relation("RosterLink", fields: [linkedPlayerProfileId], references: [id], onDelete: SetNull)
  wonMatches              ClubMatchResult[]        @relation("ClubMatchWinnerRoster")
  lostMatches             ClubMatchResult[]        @relation("ClubMatchLoserRoster")
  rankingEntries          ClubRankingEntry[]
  bonusAwards             ClubBonusPointAward[]
  memberships             Membership[]
  tournamentRegistrations TournamentRegistration[] @relation("RosterRegistrations")
  teamsAsPlayer1          TournamentTeam[]         @relation("TeamPlayer1")
  teamsAsPlayer2          TournamentTeam[]         @relation("TeamPlayer2")
  matchesAsPlayerOne      Match[]                  @relation("MatchPlayerOne")
  matchesAsPlayerTwo      Match[]                  @relation("MatchPlayerTwo")
  matchesWon              Match[]                  @relation("MatchWinner")

  @@unique([clubId, rut])
  @@index([clubId])
  @@map("club_player_roster")
}

model RankingSeason {
  id                       String              @id @default(uuid())
  clubId                   String              @map("club_id")
  label                    String
  startedAt                DateTime            @map("started_at")
  closedAt                 DateTime?           @map("closed_at")
  status                   RankingSeasonStatus @default(ACTIVE)
  carryForwardDecayPercent Int                 @default(50) @map("carry_forward_decay_percent")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  club           Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  rankingEntries ClubRankingEntry[]
  matchResults   ClubMatchResult[]
  bonusAwards    ClubBonusPointAward[]

  @@index([clubId, status])
  @@map("ranking_seasons")
}

// Per-division tier base points and promotion/relegation ordering
model ClubDivisionConfig {
  id             String @id @default(uuid())
  clubId         String @map("club_id")
  divisionKey    String @map("division_key")
  label          String
  tierBasePoints Int    @default(0) @map("tier_base_points")
  displayOrder   Int    @default(0) @map("display_order")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, divisionKey])
  @@map("club_division_configs")
}

model ClubRankingEntry {
  id          String   @id @default(uuid())
  clubId      String   @map("club_id")
  seasonId    String?  @map("season_id")
  rosterId    String   @map("roster_id")
  rank        Int
  totalPoints Int      @default(0) @map("total_points")
  gamesPlayed Int      @default(0) @map("games_played")
  withdrawn   Boolean  @default(false)
  division    String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season      RankingSeason?   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  rosterEntry ClubPlayerRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([clubId, seasonId, rosterId])
  @@index([clubId, seasonId, rank])
  @@map("club_ranking_entries")
}

model ClubMatchResult {
  id              String                @id @default(uuid())
  clubId          String                @map("club_id")
  seasonId        String?               @map("season_id")
  winnerRosterId  String?               @map("winner_roster_id")
  winnerNameRaw   String                @map("winner_name_raw")
  loserRosterId   String?               @map("loser_roster_id")
  loserNameRaw    String                @map("loser_name_raw")
  categoryKey     String                @map("category_key")
  setScores       Json?                 @map("set_scores")
  recordedAt      DateTime              @map("recorded_at")
  source          ClubMatchResultSource
  enteredByUserId String                @map("entered_by_user_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  club          Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season        RankingSeason?    @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  winnerRoster  ClubPlayerRoster? @relation("ClubMatchWinnerRoster", fields: [winnerRosterId], references: [id], onDelete: SetNull)
  loserRoster   ClubPlayerRoster? @relation("ClubMatchLoserRoster", fields: [loserRosterId], references: [id], onDelete: SetNull)
  enteredByUser User              @relation(fields: [enteredByUserId], references: [id], onDelete: Restrict)

  @@index([clubId, categoryKey])
  @@index([clubId, recordedAt])
  @@index([clubId, seasonId])
  @@map("club_match_results")
}

// Stage 6F — configurable bonus point types (auto-seeded per club)
model ClubBonusPointType {
  id     String  @id @default(uuid())
  clubId String  @map("club_id")
  key    String
  label  String
  points Int
  active Boolean @default(true)

  club   Club                  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  awards ClubBonusPointAward[]

  @@unique([clubId, key])
  @@map("club_bonus_point_types")
}

model ClubBonusPointAward {
  id              String   @id @default(uuid())
  clubId          String   @map("club_id")
  seasonId        String   @map("season_id")
  rosterId        String   @map("roster_id")
  bonusTypeId     String   @map("bonus_type_id")
  awardedByUserId String   @map("awarded_by_user_id")
  awardedAt       DateTime @default(now()) @map("awarded_at")
  note            String?

  club          Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season        RankingSeason      @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  rosterEntry   ClubPlayerRoster   @relation(fields: [rosterId], references: [id], onDelete: Restrict)
  bonusType     ClubBonusPointType @relation(fields: [bonusTypeId], references: [id], onDelete: Restrict)
  awardedByUser User               @relation(fields: [awardedByUserId], references: [id], onDelete: Restrict)

  @@map("club_bonus_point_awards")
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  announcementId String?          @map("announcement_id")
  title          String
  message        String
  type           NotificationType @default(GENERAL)
  readAt         DateTime?        @map("read_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement ClubAnnouncement? @relation(fields: [announcementId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model ClubAnnouncement {
  id           String               @id @default(uuid())
  clubId       String               @map("club_id")
  sentByUserId String               @map("sent_by_user_id")
  title        String
  body         String
  /// One of the platform-defined NotificationCategory enum values.
  /// Audience resolution filters out players who have muted this category
  /// via PlayerNotificationPreference. Critical transactional notifications
  /// (booking confirmations, 2FA codes, payment confirmations, direct match
  /// invitations, parent/child approvals, role changes) never use this field
  /// — they go through the unconditional `Notification` create path.
  category     NotificationCategory @default(EVENTS)
  createdAt    DateTime             @default(now()) @map("created_at")

  club          Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sentByUser    User           @relation("ClubAnnouncementSender", fields: [sentByUserId], references: [id], onDelete: Restrict)
  notifications Notification[]

  @@index([clubId, createdAt])
  @@map("club_announcements")
}

/// A player's "favorite" club. Independent of membership, home-club status,
/// or any roster relationship — any authenticated player can favorite any
/// club. Favoriting never creates a ClubPlayerRoster entry.
model ClubFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  clubId    String   @map("club_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
  @@map("club_favorites")
}

/// One row per player. Upserted on the first preference change. Every flag
/// defaults to TRUE — so existing players keep receiving every category
/// until they explicitly mute one. Mutes only affect category-based
/// announcements; transactional notifications (booking confirmations, 2FA
/// codes, payment confirmations, direct match invitations, parent/child
/// approvals, role changes) are never routed through this preference row.
model PlayerNotificationPreference {
  userId                 String   @id @map("user_id")
  notifyEvents           Boolean  @default(true) @map("notify_events")
  notifyOffers           Boolean  @default(true) @map("notify_offers")
  notifyMembershipOffers Boolean  @default(true) @map("notify_membership_offers")
  notifyMatchFinding     Boolean  @default(true) @map("notify_match_finding")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("player_notification_preferences")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation("ActorLogs", fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

// ─── MATCH INVITATIONS (Stage 3) ─────────────────────────────────────────────

model MatchInvitation {
  id            String           @id @default(uuid())
  requesterId   String           @map("requester_id")
  recipientId   String           @map("recipient_id")
  actedByUserId String?          @map("acted_by_user_id")
  status        InvitationStatus @default(PENDING)
  message       String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  requester   PlayerProfile @relation("SentInvitations", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   PlayerProfile @relation("ReceivedInvitations", fields: [recipientId], references: [id], onDelete: Cascade)
  actedByUser User?         @relation("ActedInvitations", fields: [actedByUserId], references: [id])

  @@map("match_invitations")
}

// ─── MATCH LOG (Stage 4) ─────────────────────────────────────────────────────

model MatchLogEntry {
  id           String       @id @default(uuid())
  playerId     String       @map("player_id")
  opponentId   String?      @map("opponent_id")
  opponentName String?      @map("opponent_name")
  type         MatchLogType @default(MATCH)
  date         DateTime
  durationMins Int?         @map("duration_mins")
  location     String?
  notes        String?
  setsData     Json?        @map("sets_data")
  playerWon    Boolean?     @map("player_won")
  bestOf       Int          @default(3) @map("best_of")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  player   PlayerProfile  @relation("OwnedMatchLogs", fields: [playerId], references: [id], onDelete: Cascade)
  opponent PlayerProfile? @relation("OpponentMatchLogs", fields: [opponentId], references: [id])

  @@map("match_log_entries")
}

// ─── PLATFORM SETTINGS ───────────────────────────────────────────────────────

model PlatformSetting {
  key             String   @id
  value           String
  updatedAt       DateTime @updatedAt @map("updated_at")
  updatedByUserId String?  @map("updated_by_user_id")

  @@map("platform_settings")
}

// ─── PARENT-CHILD LINKS (Stage 10) ───────────────────────────────────────────

model ParentChildLink {
  id               String                @id @default(uuid())
  parentUserId     String                @map("parent_user_id")
  childUserId      String                @map("child_user_id")
  clubId           String                @map("club_id")
  status           ParentChildLinkStatus @default(PENDING)
  requestedAt      DateTime              @default(now()) @map("requested_at")
  approvedByUserId String?               @map("approved_by_user_id")
  approvedAt       DateTime?             @map("approved_at")

  parent     User  @relation("ParentLinks", fields: [parentUserId], references: [id])
  child      User  @relation("ChildLinks", fields: [childUserId], references: [id])
  club       Club  @relation(fields: [clubId], references: [id])
  approvedBy User? @relation("ApprovedLinks", fields: [approvedByUserId], references: [id])

  @@map("parent_child_links")
}
