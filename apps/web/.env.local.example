# ─── Raqueta Web App — Next.js Environment ──────────────────────────────────
# Copy this file to .env.local and fill in values.

# REQUIRED. Base URL of the NestJS API (no trailing slash).
# In dev: http://localhost:3001/api/v1
# On a physical mobile test device: use your LAN IP, e.g. http://192.168.1.x:3001/api/v1
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
