{
  "expo": {
    "name": "Raqueta",
    "slug": "raqueta",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.raqueta",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Allow Raqueta to connect to the local development server while testing on this device."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "app.raqueta"
    },
    "scheme": "raqueta",
    "plugins": ["expo-router"]
  }
}
