# ─── Raqueta Mobile App — Expo Environment ──────────────────────────────────
# Copy this file to .env and fill in values.
# All EXPO_PUBLIC_* vars are bundled into the JS bundle — never put secrets here.

# REQUIRED. Base URL of the NestJS API (no trailing slash).
# iOS Simulator on the same Mac: http://localhost:3001/api/v1
# Physical iOS/Android device: http://<your-LAN-IP>:3001/api/v1
#   (find your LAN IP with: ipconfig getifaddr en0)
EXPO_PUBLIC_API_URL="http://localhost:3001/api/v1"
