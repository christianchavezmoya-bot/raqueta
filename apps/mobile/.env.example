# ─── Raqueta Mobile App — Expo Environment ──────────────────────────────────
# Copy this file to .env and fill in values.
# All EXPO_PUBLIC_* vars are bundled into the JS bundle — never put secrets here.

# REQUIRED. Base URL of the NestJS API (no trailing slash).
# iOS Simulator on the same Mac: http://localhost:3001/api/v1
# Physical iOS/Android device: http://<your-LAN-IP>:3001/api/v1
#   (find your LAN IP with: ipconfig getifaddr en0)
EXPO_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ─── MAPS (Android only) ─────────────────────────────────────────────────────
# Required for the club-discovery map view on Android.
# iOS uses Apple Maps natively and does not need a key.
#
# Steps to obtain:
#   1. Go to console.cloud.google.com → same project as GOOGLE_GEOCODING_API_KEY
#   2. Enable "Maps SDK for Android" API
#   3. Create an API key restricted to:
#        Application restriction: Android apps
#        Package name: app.ngo
#        SHA-1: `keytool -list -v -keystore ~/.android/debug.keystore` (debug)
#               (use your release keystore SHA-1 for production builds)
#        API restriction: Maps SDK for Android only
#
# NOTE: read at BUILD TIME by app.config.js — NOT bundled into the JS bundle.
GOOGLE_MAPS_ANDROID_KEY=""
