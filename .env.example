# ─── DATABASE ───────────────────────────────────────────────────────────────
# Local Postgres via Homebrew (brew services start postgresql@16)
# or Docker (docker compose up -d postgres)
DATABASE_URL="postgresql://raqueta_user:raqueta_pass@localhost:5432/raqueta_db"

# ─── AUTH ───────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET="change-this-super-secret-jwt-key-in-production"
# REQUIRED. Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET="change-this-super-secret-refresh-key-in-production"
# Optional — defaults shown
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── APP ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_PREFIX="api/v1"
# Origin allowed by CORS for the web dashboard
FRONTEND_URL="http://localhost:3000"
# Origin allowed by CORS for the Expo app (use your LAN IP if testing on a physical device)
MOBILE_URL="exp://localhost:8081"

# ─── STORAGE ────────────────────────────────────────────────────────────────
# "local" uses the local filesystem (default for dev). Set to "s3" when ready.
STORAGE_PROVIDER="local"
# MUST be an absolute path — e.g. /home/user/raqueta/apps/api/storage
# WARNING: a relative path (./storage) is resolved against process.cwd() at startup.
# If the API is ever started from a different working directory the path changes,
# silently writing new uploads to a different folder and making previously uploaded
# files appear to disappear. Always use an absolute path here.
STORAGE_ROOT="/absolute/path/to/raqueta/apps/api/storage"
# Public base URL used to build URLs for uploaded media. Must match where the API is reachable.
API_BASE_URL="http://localhost:3001"

# ─── MAPS / GEOCODING ───────────────────────────────────────────────────────
# Required for automatic geocoding when a club address is saved or changed.
GOOGLE_GEOCODING_API_KEY=""

# ─── BACKUPS ────────────────────────────────────────────────────────────────
# Distinct backup folder. For production, point this at truly separate encrypted storage.
BACKUP_ROOT="./backups"
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=6

# ─── NOTIFICATIONS ──────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in dev — email content is printed to the API console log instead.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@raqueta.app"

# ─── PAYMENTS (future) ──────────────────────────────────────────────────────
# Leave blank in dev — payment endpoints exist but are not wired to a live gateway yet.
STRIPE_SECRET_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
WEBPAY_API_KEY=""

# ─── S3 / OBJECT STORAGE (future) ───────────────────────────────────────────
# Required only when STORAGE_PROVIDER=s3
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
