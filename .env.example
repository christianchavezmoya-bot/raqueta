# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://raqueta_user:raqueta_pass@localhost:5432/raqueta_db"

# ─── AUTH ───────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-super-secret-jwt-key-in-production"
JWT_REFRESH_SECRET="change-this-super-secret-refresh-key-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── APP ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3001
API_PREFIX="api/v1"
FRONTEND_URL="http://localhost:3000"
MOBILE_URL="exp://localhost:8081"

# ─── STORAGE ────────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ─── NOTIFICATIONS ──────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@raqueta.app"

# ─── PAYMENTS (Phase 2) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
MERCADOPAGO_ACCESS_TOKEN=""
WEBPAY_API_KEY=""
